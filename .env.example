HOST=127.0.0.1
PORT=4000
ALLOW_LAN_ACCESS=false
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
JSON_BODY_LIMIT_BYTES=5242880
UPLOAD_FILE_SIZE_LIMIT_BYTES=2147483648
STORAGE_ROOT=./data
MAX_CONCURRENT_MEDIA_JOBS=1
SHUTDOWN_GRACE_PERIOD_MS=15000
MEDIA_PROCESS_TIMEOUT_MS=1800000
TOOL_COMMAND_TIMEOUT_MS=60000
PROCESS_KILL_GRACE_PERIOD_MS=5000
MAX_CAPTURED_PROCESS_OUTPUT_BYTES=4194304
VITE_API_BASE_URL=http://localhost:4000
YT_DLP_BIN=C:\path\to\yt-dlp.exe
# Optional. The API automatically passes its current Node runtime to yt-dlp.
YT_DLP_JS_RUNTIME=node:C:\Program Files\nodejs\node.exe
