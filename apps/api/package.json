{
  "name": "@local-video-optimizer/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration:media": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@local-video-optimizer/contracts": "file:../../packages/contracts",
    "@local-video-optimizer/video-core": "file:../../packages/video-core",
    "express": "^4.19.2",
    "multer": "^2.2.0",
    "nanoid": "^5.0.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.10",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^5.5.3"
  }
}
